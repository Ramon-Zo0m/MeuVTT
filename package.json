{
  "name": "OpenVTT",
  "version": "1.0.0",
  "description": "OpenVTT",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "Ramon Caruso",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ip": "^1.1.8",
    "socket.io": "^4.7.2",
    "konva": "^9.2.0"
  },
  "devDependencies": {
    "electron": "^26.0.0",
    "electron-builder": "^24.6.0"
  },
  "build": {
    "appId": "com.Ramon.openvtt",
    "productName": "OpenVTT",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico" 
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "build/icon.ico", 
      "uninstallerIcon": "build/icon.ico" 
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  }
}